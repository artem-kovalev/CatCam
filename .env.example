# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Telegram bot token issued by @BotFather (looks like "123456789:AA...").
TELEGRAM_BOT_TOKEN=

# Numeric Telegram user id of the sole authorized owner (get it from @userinfobot,
# or from the bot's own /start log the first time you message it).
TELEGRAM_USER_ID=

# Numeric Telegram chat id notifications/clips are sent to. For a private 1:1
# chat with the bot this is usually the same value as TELEGRAM_USER_ID.
TELEGRAM_CHAT_ID=

# Optional: absolute path to config/config.yaml if it lives outside the repo
# (e.g. /etc/catcam/config.yaml on a deployed Raspberry Pi). Leave unset to use
# the repo-relative config/config.yaml.
CATCAM_CONFIG_PATH=

# Optional: password for MediaMTX's "catcam-viewer" account (see
# docs/streaming.md), used by /snapshot, /record, and the motion pipeline to
# read frames from the RTSP feed instead of opening the camera directly. Must
# match MTX_AUTHINTERNALUSERS_1_PASS in /etc/catcam/mediamtx.env. Leave unset
# to fall back to a direct camera open (only valid while streaming is stopped).
CATCAM_STREAM_VIEW_PASSWORD=
